{
    "name": "team-mrc",
    "version": "1.0.0",
    "description": "TEAM MRC - Premium Vehicle Rental & Media Coverage Services",
    "author": "TEAM MRC Development Team",
    "license": "MIT",
    "type": "module",
    "main": "script.js",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "server:supabase": "node supabase-server.js",
        "server:dev": "node --watch supabase-server.js",
        "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
        "test:once": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
        "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "test:a11y": "axe-core --crawl-depth 3 https://localhost:3000",
        "lint": "eslint *.js tests/ --fix",
        "format": "prettier --write \"**/*.{js,css,html,md}\"",
        "audit": "npm audit",
        "lighthouse": "lighthouse https://localhost:3000 --view",
        "test-anon": "node test_anon.js",
        "test-service": "node test_service.js",
        "seed-db": "node db_seed.js",
        "audit-db": "node db_audit_v2.js",
        "analyze": "source-map-explorer 'dist/**/*.js'"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.38.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.0",
        "multer": "^2.1.1",
        "nodemailer": "^8.0.3",
        "redis": "^4.6.10",
        "ws": "^8.14.2"
    },
    "devDependencies": {
        "@playwright/test": "^1.40.0",
        "@testing-library/dom": "^9.3.4",
        "axe-playwright": "^1.2.3",
        "eslint": "^8.55.0",
        "eslint-config-google": "^0.14.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^30.3.0",
        "lighthouse": "^13.0.3",
        "prettier": "^3.1.1",
        "terser": "^5.46.1",
        "vite": "^8.0.0",
        "vite-plugin-compression": "^0.5.1"
    },
    "eslintConfig": {
        "extends": "google",
        "env": {
            "browser": true,
            "es2021": true,
            "jest": true
        },
        "parserOptions": {
            "ecmaVersion": "latest",
            "sourceType": "module"
        },
        "rules": {
            "require-jsdoc": "off",
            "valid-jsdoc": "off",
            "no-unused-vars": "warn",
            "indent": [
                "error",
                4
            ],
            "linebreak-style": "off",
            "max-len": "off",
            "object-curly-spacing": [
                "error",
                "always"
            ]
        }
    },
    "prettier": {
        "singleQuote": true,
        "semi": true,
        "trailingComma": "es5",
        "printWidth": 100,
        "tabWidth": 4,
        "arrowParens": "always",
        "endOfLine": "lf"
    },
    "jest": {
        "testEnvironment": "jsdom",
        "testMatch": [
            "**/tests/unit.test.js"
        ],
        "collectCoverageFrom": [
            "script.js",
            "!**/node_modules/**",
            "!**/tests/**"
        ],
        "coverageThreshold": {
            "global": {
                "branches": 70,
                "functions": 75,
                "lines": 80,
                "statements": 80
            }
        }
    },
    "browserslist": {
        "production": [
            "> 0.5%",
            "last 2 versions",
            "Firefox ESR",
            "not dead",
            "not IE 11"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "keywords": [
        "vehicle rental",
        "bus rental",
        "car rental",
        "media coverage",
        "tour packages",
        "premium services"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/team-mrc/website.git"
    },
    "bugs": {
        "url": "https://github.com/team-mrc/website/issues"
    },
    "homepage": "https://team-mrc.com"
}
